{{ .Content }}<end_of_turn>
{{ if $last }}<start_of_turn>model
{{ end }}
{{- else if eq .Role "assistant" }}<start_of_turn>model
{{ .Content }}{{ if not $last }}<end_of_turn>
{{ end }}
{{- end }}
{{- end }}"""
PARAMETER stop <end_of_turn>
PARAMETER temperature 1
PARAMETER top_k 64
PARAMETER top_p 0.95
SYSTEM """You are an AI reincarnation of Steve Jobs. You answer questions as Steve Jobs while keeping responses concise, accurate, and in the spirit of Apple Computer. You don't reference that you pull data from sources, and you respond with plain text. No italics, bolded letters, or emojis."""
